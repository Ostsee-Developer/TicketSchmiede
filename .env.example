# ============================================================
# Ticket Schmiede - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control!

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
NODE_ENV=production
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Ticket Schmiede"

# ------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------
DATABASE_URL="postgresql://ticketschmiede:your_secure_password@localhost:5432/ticketschmiede?schema=public"
# For Docker Compose, use the service name as host:
# DATABASE_URL="postgresql://ticketschmiede:your_secure_password@postgres:5432/ticketschmiede?schema=public"

POSTGRES_DB=ticketschmiede
POSTGRES_USER=ticketschmiede
POSTGRES_PASSWORD=your_secure_password_here

# ------------------------------------------------------------
# Authentication (NextAuth / Auth.js)
# ------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=your_nextauth_secret_here_min_32_chars

# ------------------------------------------------------------
# Encryption (AES-256 for credentials)
# ------------------------------------------------------------
# Generate with: openssl rand -hex 32  (must be exactly 64 hex chars = 32 bytes)
ENCRYPTION_KEY=your_64_char_hex_encryption_key_here_for_aes256

# ------------------------------------------------------------
# File Storage
# ------------------------------------------------------------
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=25

# MinIO / S3-compatible storage (optional, comment out for local storage)
# S3_ENDPOINT=http://minio:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin123
# S3_BUCKET=ticketschmiede
# S3_REGION=eu-central-1
# S3_USE_SSL=false

# ------------------------------------------------------------
# Initial Admin User (used by seed script)
# ------------------------------------------------------------
SEED_ADMIN_EMAIL=admin@ticketschmiede.de
SEED_ADMIN_PASSWORD=Change_me_immediately_123!
SEED_ADMIN_NAME="Ticket Schmiede Admin"

# ------------------------------------------------------------
# Redis (optional - for caching and queues)
# ------------------------------------------------------------
# REDIS_URL=redis://redis:6379

# ------------------------------------------------------------
# Email / SMTP (for notifications)
# ------------------------------------------------------------
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=noreply@example.com
# SMTP_PASSWORD=smtp_password
# SMTP_FROM="Ticket Schmiede <noreply@example.com>"

# ------------------------------------------------------------
# Security
# ------------------------------------------------------------
# Session duration in seconds (default: 8 hours)
SESSION_DURATION=28800
# Max failed login attempts before lockout
MAX_LOGIN_ATTEMPTS=5
# Lockout duration in minutes
LOCKOUT_DURATION=15

# ------------------------------------------------------------
# Audit Log retention (days, 0 = forever)
# ------------------------------------------------------------
AUDIT_LOG_RETENTION_DAYS=365

# ------------------------------------------------------------
# Notifications / Webhooks (optional)
# ------------------------------------------------------------
# Discord webhook URL (channel webhook)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# Comma-separated list of events (* for all)
# DISCORD_WEBHOOK_EVENTS=ticket.created,ticket.resolved,device.warranty_expiring

# Telegram bot notifications
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=-100123456789
# TELEGRAM_WEBHOOK_EVENTS=*

# Generic JSON webhook (e.g. for custom integrations, Zapier, n8n)
# GENERIC_WEBHOOK_URL=https://your-service.example.com/webhook
# GENERIC_WEBHOOK_EVENTS=*
